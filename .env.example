# Copy to .env.local and fill in.
#
# Toggle mock data (true) vs the live backend (false).
# Day 1 of the student build: leave this true.
VITE_USE_MOCKS=true

# Live backend URL — used only when VITE_USE_MOCKS=false.
# The Stage-2 /api/captures route runs on the existing dashboard service.
VITE_API_BASE_URL=https://wildlife-dashboard-ee47ntxftq-uw.a.run.app

# Firebase web app config — safe to expose (these values are public by design).
# Get them from Firebase console > Project settings > Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=louielabs-animal-cams.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=louielabs-animal-cams
VITE_FIREBASE_APP_ID=
